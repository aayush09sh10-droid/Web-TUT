NODE_ENV=development
HOST=0.0.0.0
PORT=5001

MONGODB_URI=mongodb+srv://username:password@cluster.example.mongodb.net/
DB_NAME=web_tutor

CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

ACCESS_TOKEN_SECRET=replace-with-a-long-random-secret
ACCESS_TOKEN_ENTRY=7d
AUTH_COOKIE_DAYS=30

GEMINI_API_KEY=replace-with-your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash
GEMINI_FALLBACK_MODELS=gemini-2.5-flash-lite,gemini-2.0-flash,gemini-flash-latest
GEMINI_AUDIO_CHUNK_SECONDS=300

CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

REDIS_REQUIRED=true
REDIS_URL=rediss://default:password@your-redis-host:6379
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_CACHE_PREFIX=web-tutor

LOG_LEVEL=debug

HTTPS_ENABLED=false
HTTPS_KEY_PATH=
HTTPS_CERT_PATH=
